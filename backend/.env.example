# --- Database ---
DATABASE_URL=postgresql+psycopg2://nullarchive:nullarchive@localhost:5432/nullarchive

# --- Auth ---
SECRET_KEY=change-this-to-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=60
ALGORITHM=HS256

# --- Storage abstraction ---
# "local" writes to STORAGE_LOCAL_PATH. Switch to "supabase" once you're
# ready to connect Supabase Storage (or another S3-compatible provider).
STORAGE_BACKEND=local
STORAGE_LOCAL_PATH=./uploads

SUPABASE_URL=
SUPABASE_SERVICE_KEY=
SUPABASE_BUCKET=nullarchive-attachments

# --- App ---
FRONTEND_ORIGIN=http://localhost:5173
